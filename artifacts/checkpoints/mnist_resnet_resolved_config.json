{
  "experiment": {
    "seed": 42,
    "device": "cuda",
    "deterministic": true,
    "allow_tf32": false
  },
  "dataset": {
    "name": "mnist",
    "image_size": 28,
    "channels": 1,
    "conditional": false,
    "num_classes": null
  },
  "model": {
    "architecture": "resnet",
    "in_channels": 1,
    "out_channels": 1,
    "embedding_dim": 256,
    "padding": "zeros",
    "normalization": "none",
    "hidden_channels": 256,
    "kernel_size": 3,
    "num_mid_layers": 6,
    "channel_mults": null,
    "downsample": null,
    "upsample": null,
    "skip_connection": null
  },
  "training": {
    "epochs": 300,
    "batch_size": 128,
    "optimizer": {
      "name": "adam",
      "lr": 0.0001,
      "weight_decay": 0.0,
      "betas": [
        0.9,
        0.999
      ],
      "eps": 1e-08
    },
    "lr_schedule": {
      "name": "exponential_from_half_life",
      "halve_every_epochs": 50.0,
      "step_unit": "optimizer_step"
    }
  },
  "diffusion": {
    "prediction_type": "eps",
    "horizon": 1000,
    "noise_schedule": "cosine",
    "sampler": {
      "name": "ddim",
      "steps": 20,
      "eta": 0.0
    }
  },
  "logging": {
    "save_every_epochs": 25,
    "sample_every_epochs": 25
  },
  "artifacts": {
    "checkpoints_dir": "artifacts/checkpoints",
    "samples_dir": "artifacts/samples",
    "seeds_dir": "artifacts/seeds"
  }
}